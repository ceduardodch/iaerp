{
  "id": "iaerp",
  "realm": "iaerp",
  "displayName": "IAERP",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "organizationsEnabled": true,
  "accessTokenLifespan": 300,
  "sslRequired": "external",
  "users": [
    {
      "id": "22222222-2222-4222-8222-222222222222",
      "username": "owner",
      "email": "owner@iaerp.local",
      "firstName": "IAERP",
      "lastName": "Owner",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "DemoPass123!",
          "temporary": false
        }
      ]
    }
  ],
  "organizations": [
    {
      "id": "33333333-3333-4333-8333-333333333333",
      "name": "IAERP Demo",
      "alias": "iaerp-demo",
      "enabled": true,
      "domains": [
        {
          "name": "iaerp.local",
          "verified": true
        }
      ],
      "members": [
        {
          "id": "22222222-2222-4222-8222-222222222222",
          "username": "owner",
          "email": "owner@iaerp.local",
          "enabled": true
        }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "organization",
      "description": "Organization membership for tenant selection",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "organization",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-membership-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "multivalued": "true",
            "addOrganizationId": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "organization",
            "jsonType.label": "JSON"
          }
        }
      ]
    },
    {
      "name": "context:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "organization:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "parties:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "parties:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "products:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "products:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],
  "clients": [
    {
      "clientId": "iaerp-web",
      "name": "IAERP Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:8088/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:8088"
      ],
      "defaultClientScopes": [
        "context:read",
        "organization:read",
        "parties:read",
        "parties:write",
        "products:read",
        "products:write"
      ],
      "optionalClientScopes": [
        "organization"
      ],
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "iaerp-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "iaerp-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "iaerp-mcp-cli",
      "name": "IAERP MCP local PoC",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://127.0.0.1:*/*"
      ],
      "webOrigins": [],
      "defaultClientScopes": [
        "context:read",
        "parties:read",
        "products:read"
      ],
      "optionalClientScopes": [
        "organization",
        "parties:write",
        "products:write"
      ],
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "iaerp-mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "http://localhost:8000/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ]
}
